# Agnes AI API 配置（本地开发CLI使用）
AGNES_API_KEY=sk-your-key-here
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# 图片生成模型
AGNES_IMAGE_MODEL=agnes-image-2.1-flash

# 视频生成模型
AGNES_VIDEO_MODEL=agnes-video-v2.0

# AI 聚合搜索与分析（必填，否则 AI 推荐/摘要/演员分析功能不可用）
UNLIMITED_AI_KEY=your-unlimited-ai-key-here

# 信任网络自动登录角色（admin 或 user），默认 admin
TRUSTED_NETWORK_ROLE=admin

# Cloudflare 账户 ID（wrangler.toml 使用，通过环境变量注入）
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Telegram Webhook 额外允许的 Host（逗号分隔）
TELEGRAM_WEBHOOK_EXTRA_HOSTS=
